# Generated by /assess (ai-native-toolkit v$plugin_version) on $generated_date.
# Re-run /assess and choose "Freeze this into a repeatable check?" to regenerate.
#
# This workflow runs the AI-Readiness Assess Gate action on every pull request:
# the deterministic /assess core (complexity treemap, promissory-marker scan,
# doc-graph signals), gated on the [gate] section of .assess/config.toml. Both
# check kinds are warn-only until you opt in: AI-readiness FLOORS (a fail_on
# finding present, a containment drop, p95 complexity past a threshold) and a
# true REGRESSION check (fail_on_regression) against the prior committed
# snapshot. No AI is in this loop - it is the frozen contract version of the
# assessment you just ran by hand.
#
# The gate logic lives in the action (bjcoombs/ai-native-toolkit@v$plugin_version),
# pinned to an immutable release tag. Because the pin sits on a `uses:` line,
# Dependabot and Renovate can see it and will propose upgrades when a newer
# toolkit release exists. To enable that, add a .github/dependabot.yml with:
#
#   version: 2
#   updates:
#     - package-ecosystem: github-actions
#       directory: /
#       schedule:
#         interval: weekly
#
# Infra failures (tool installs, uv setup) degrade to a skip notice inside the
# action, never a red check. The only thing that fails a PR is what
# .assess/config.toml opts into.
name: Assess Gate

on:
  pull_request:
    branches: [$default_branch]

permissions:
  contents: read

jobs:
  assess:
    name: AI-readiness regression gate
    runs-on: ubuntu-latest
    steps:
      - name: Check out the repository
        uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6.0.3
        with:
          fetch-depth: 0  # full history so the churn window is accurate
          persist-credentials: false  # nothing here pushes; don't leave a token in .git
$tool_steps
      - name: Run the AI-readiness gate
        # First-party action, pinned to an IMMUTABLE release tag (this repo
        # publishes immutable releases, so the tag cannot be re-pointed - the
        # property SHA-pinning exists to guarantee). Dependabot reads this line.
        uses: bjcoombs/ai-native-toolkit@v$plugin_version
        with:
          config: .assess/config.toml
